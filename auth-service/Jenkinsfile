pipeline {
agent any

```
environment {
    SERVICE_NAME = 'auth-service'
    IMAGE_NAME   = 'securebank-auth'
    IMAGE_TAG    = "1.0.${BUILD_NUMBER}"
    NEXUS_URL    = "${NEXUS_HOST}:8082"
    APP_PORT     = '8081'
}

tools {
    maven 'maven-3.9'
    jdk 'jdk21'
}

stages {

    stage('Checkout') {
        steps {
            checkout scm
        }
    }

    stage('Compile') {
        steps {
            dir("${SERVICE_NAME}") {
                sh 'mvn clean compile -B'
            }
        }
    }

    stage('Unit Test') {
        steps {
            dir("${SERVICE_NAME}") {
                sh 'mvn test -B'
            }
        }
        post {
            always {
                junit allowEmptyResults: true,
                testResults: "${SERVICE_NAME}/target/surefire-reports/*.xml"
            }
        }
    }

    stage('SonarQube Scan') {
        steps {
            dir("${SERVICE_NAME}") {
                withSonarQubeEnv('SonarQube') {
                    sh 'mvn sonar:sonar -Dsonar.projectKey=securebank-auth -B'
                }
            }
        }
    }

    stage('Quality Gate') {
        steps {
            timeout(time: 5, unit: 'MINUTES') {
                waitForQualityGate abortPipeline: true
            }
        }
    }

    stage('Package JAR') {
        steps {
            dir("${SERVICE_NAME}") {
                sh 'mvn package -DskipTests -B'
                archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
            }
        }
    }
}

post {
    success {
        echo "Build Successful"
    }

    failure {
        echo "Build Failed"
    }

    always {
        cleanWs()
    }
}
```

}
